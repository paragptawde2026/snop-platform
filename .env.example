# ── Copy this file to .env and fill in values ─────────────────────────────
# On Linux/Mac:  cp .env.example .env
# On Windows:    copy .env.example .env

# ── Server public URL (IP or domain, no trailing slash) ───────────────────
# Examples:
#   SERVER_URL=http://159.100.12.34
#   SERVER_URL=https://snop.yourdomain.com
SERVER_URL=http://YOUR_SERVER_IP

# ── Database ──────────────────────────────────────────────────────────────
POSTGRES_USER=snop_admin
POSTGRES_PASSWORD=CHANGE_ME_strong_db_password
POSTGRES_DB=snop_production

# ── App secret key ────────────────────────────────────────────────────────
# Generate with:  openssl rand -hex 32
SECRET_KEY=CHANGE_ME_run_openssl_rand_hex_32

# ── Derived — do not edit unless you know what you're doing ───────────────
VITE_API_BASE_URL=${SERVER_URL}
CORS_ORIGINS=${SERVER_URL}
ENVIRONMENT=production
